# Railway Production Environment Variables Template
# Copy these values to Railway environment variables

# === API VARIABLES ===
DATABASE_URL=mysql://username:password@host:port/database
# ↑ Railway MySQL will provide this automatically

JWT_SECRET=cripto-conversor-super-secret-jwt-key-production-2025
JWT_EXPIRES_IN=7d
API_PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=https://your-web-service.railway.app
COINGECKO_BASE=https://api.coingecko.com/api/v3

# === WEB VARIABLES ===  
VITE_API_URL=https://your-api-service.railway.app

# === RAILWAY SETUP NOTES ===
# 1. Add MySQL database service
# 2. Copy DATABASE_URL from MySQL service to API variables  
# 3. Deploy API first, copy URL to CORS_ORIGIN
# 4. Deploy Web, copy URL to VITE_API_URL
# 5. Update CORS_ORIGIN in API with Web URL
